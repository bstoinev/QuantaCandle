#!/usr/bin/env pwsh
# Git Pre-Commit Hook for File Structure Validation
# This hook validates that staged C# files follow the naming convention:
# - Each file contains exactly one top-level type
# - Filename matches the type name exactly
#
# Exit code 0 = all checks passed, commit allowed
# Exit code 1 = violations found, commit blocked

# Get the list of staged .cs files
$stagedFiles = @(git diff --cached --name-only --diff-filter=ACM 2>$null | Where-Object { $_ -like "*.cs" })

if ($stagedFiles.Count -eq 0) {
    exit 0  # No C# files staged, allow commit
}

$validationErrors = @()

foreach ($file in $stagedFiles) {
    # Skip bin/ and obj/ directories
    if ($file -match "\\(obj|bin)\\") {
        continue
    }

    # Get the content of the staged file
    $content = git show ":$file" 2>$null
    if ($null -eq $content) {
        continue
    }

    $fileName = [System.IO.Path]::GetFileNameWithoutExtension($file)

    # Find all top-level type declarations
    $pattern = '(?:public|internal|private|protected|sealed|abstract|static|partial|\s)+(?:class|interface|enum|record|struct|delegate)\s+(\w+)'
    $matches = [regex]::Matches($content, $pattern)

    if ($matches.Count -eq 0) {
        # It's OK to have no types
        continue
    }

    # Extract type names from matches
    $typeNames = @()
    foreach ($match in $matches) {
        $typeNames += $match.Groups[1].Value
    }

    # Check for multiple distinct types in one file
    $uniqueTypes = $typeNames | Select-Object -Unique
    if ($uniqueTypes.Count -gt 1) {
        $validationErrors += "File '$file' contains multiple top-level types: $($uniqueTypes -join ', '). Each file should contain only one type."
        continue
    }

    # Check if filename matches type name
    $typeName = $typeNames[0]
    if ($typeName -ne $fileName) {
        $validationErrors += "File '$file' declares type '$typeName'. Filename must match type name (expected: '$typeName.cs')."
    }
}

# Block commit if validation errors found
if ($validationErrors.Count -gt 0) {
    Write-Host ""
    Write-Host "═════════════════════════════════════════════════════" -ForegroundColor Red
    Write-Host "FILE STRUCTURE VALIDATION FAILED - COMMIT BLOCKED" -ForegroundColor Red
    Write-Host "═════════════════════════════════════════════════════" -ForegroundColor Red
    Write-Host ""
    Write-Host "The following file(s) violate the naming convention:" -ForegroundColor Yellow
    Write-Host "  Rule: Filename must match the type name exactly" -ForegroundColor Yellow
    Write-Host ""

    foreach ($err in $validationErrors) {
        Write-Host "  ✗ $err" -ForegroundColor Red
    }

    Write-Host ""
    Write-Host "Fix the violations by renaming files to match their type names:" -ForegroundColor Yellow
    Write-Host "  Example: class MyClass should be in file MyClass.cs" -ForegroundColor Yellow
    Write-Host ""

    exit 1
}

exit 0
