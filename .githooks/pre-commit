#!/usr/bin/env bash
# Git Pre-Commit Hook for File Structure Validation
# Validates staged C# files follow the naming convention:
# - Each file contains at most one top-level type declaration
# - If a type is declared, the filename must match the type name exactly
#
# Exit code 0 = all checks passed, commit allowed
# Exit code 1 = violations found, commit blocked

set -euo pipefail

staged_files="$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' 2>/dev/null || true)"
if [ -z "$staged_files" ]; then
  exit 0
fi

validation_errors=()

while IFS= read -r file; do
  [ -z "$file" ] && continue

  case "$file" in
    */bin/*|*/obj/*) continue ;;
  esac

  content="$(git show ":$file" 2>/dev/null || true)"
  [ -z "$content" ] && continue

  file_name="${file##*/}"
  file_name="${file_name%.cs}"

  type_names="$(
    printf '%s\n' "$content" \
      | grep -oE '^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*[[:space:]]+)*(class|interface|enum|record|struct|delegate)[[:space:]]+[A-Za-z_][A-Za-z0-9_]*' \
      | awk '{print $NF}' \
      || true
  )"

  if [ -z "$type_names" ]; then
    continue
  fi

  type_count="$(printf '%s\n' "$type_names" | wc -l | tr -d '[:space:]')"
  if [ "$type_count" -gt 1 ]; then
    types_list="$(printf '%s\n' "$type_names" | sort -u | tr '\n' ', ' | sed 's/, $//')"
    validation_errors+=("File '$file' contains multiple top-level types: $types_list. Each file should contain only one type.")
    continue
  fi

  type_name="$(printf '%s\n' "$type_names" | head -n 1)"
  if [ "$type_name" != "$file_name" ]; then
    validation_errors+=("File '$file' declares type '$type_name'. Filename must match type name (expected: '$type_name.cs').")
  fi
done <<< "$staged_files"

if [ "${#validation_errors[@]}" -gt 0 ]; then
  echo ""
  echo "============================================================"
  echo "FILE STRUCTURE VALIDATION FAILED - COMMIT BLOCKED"
  echo "============================================================"
  echo ""
  echo "The following file(s) violate the naming convention:"
  echo "  Rule: Filename must match the type name exactly"
  echo ""

  for err in "${validation_errors[@]}"; do
    echo "  - $err"
  done

  echo ""
  echo "Fix the violations by renaming files to match their type names:"
  echo "  Example: class MyClass should be in file MyClass.cs"
  echo ""
  exit 1
fi

exit 0
