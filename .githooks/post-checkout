#!/usr/bin/env bash
# Auto-configure Git hooks on clone/checkout
# This ensures core.hooksPath is set even if developer forgets setup script
# Runs automatically after git checkout or git clone operations

HOOKS_PATH=$(git config core.hooksPath 2>/dev/null)

if [ -z "$HOOKS_PATH" ]; then
    git config core.hooksPath .githooks
    echo "[QuantaCandle] Git hooks automatically configured"
fi

exit 0
