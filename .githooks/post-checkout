#!/usr/bin/env bash
# Git hook recovery: restore core.hooksPath if cleared
#
# Note: Git does not run hooks from the repo automatically right after clone.
# This hook is copied into `.git/hooks/post-checkout` by `setup-hooks.sh` so it
# can run even if `core.hooksPath` is later missing.

hooks_path="$(git config core.hooksPath 2>/dev/null || true)"

if [ -z "$hooks_path" ]; then
  git config core.hooksPath .githooks
  echo "[QuantaCandle] Git hooks automatically configured (core.hooksPath=.githooks)"
fi

exit 0
