{
    "version": "2.0.0",
    "tasks": [
        {
        "label": "Run All Tests",
        "type": "shell",
        "command": "dotnet",
        "args": [
            "test",
            "QuantaCandle.slnx",
            "--configuration",
            "Debug",
            "--verbosity",
            "minimal"
        ],
        "group": "test",
        "problemMatcher": "$msCompile"
        },
        {
        "label": "Run Tests With Coverage",
        "type": "shell",
        "command": "dotnet",
        "args": [
            "test",
            "QuantaCandle.slnx",
            "--collect:\"XPlat Code Coverage\"",
            "--results-directory",
            "TestResults"
        ],
        "group": "test"
        },
        {
            "label": "build-cli",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "${workspaceFolder}/src/QuantaCandle.CLI/QuantaCandle.CLI.csproj",
                "-c",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "build",
                "${workspaceFolder}/QuantaCandle.slnx",
                "-c",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
